@page
@model Web.Pages.Vehiculos.EditarModel
@{
}

<h1>Editar vehiculo</h1>

<div class="container">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">
        <form method="post">

            <div class="form-group">
                <label for="marcas">Marca</label>
                <select asp-for="marcaseleccionada" class="form-select" asp-items="Model.marcas" id="marcas" onchange="fetchModelos()">
                    <option value="">Seleccione una marca</option>
                </select>
            </div>

            <div class="form-group">
                <label for="marcas">Modelo</label>
                <select asp-for="vehiculoRequest.IdModelo" class="form-select" asp-items="Model.modelos" id="modelos">
                    <option value="">Seleccione una marca</option>
                </select>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.Placa"></label>
                <input class="form-control" asp-for="vehiculoRequest.Placa">
                <span class="text-danger" asp-validation-for="vehiculoRequest.Placa"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.Precio"></label>
                <input class="form-control" asp-for="vehiculoRequest.Precio">
                <span class="text-danger" asp-validation-for="vehiculoRequest.Precio"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.Anio"></label>
                <input class="form-control" asp-for="vehiculoRequest.Anio">
                <span class="text-danger" asp-validation-for="vehiculoRequest.Anio"></span>
            </div>

    <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.Color" />
                <input class="form-control" asp-for="vehiculoRequest.Color">
                <span class="text-danger" asp-validation-for="vehiculoRequest.Color"></span>
    </div>

    <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.CorreoPropietario" />
                <input class="form-control" asp-for="vehiculoRequest.CorreoPropietario">
                <span class="text-danger" asp-validation-for="vehiculoRequest.CorreoPropietario"></span>
    </div>

    <div class="form-group">
                <label class="control-label" asp-for="vehiculoRequest.TelefonoPropietario" />
                <input class="form-control" asp-for="vehiculoRequest.TelefonoPropietario">
                <span class="text-danger" asp-validation-for="vehiculoRequest.TelefonoPropietario"></span>
    </div>
    </form>
    </div>
</div>

@section Scripts{
        <script>
            async function fetchModelos() {
                const marcaId = document.getElementById('marcas').value;
                if (!marcaId) {
                    return;
                }
                try {
                    const response = await fetch(`?handler=ObtenerModelos&marcaId=${marcaId}`);
                    if (!response.ok) {
                        throw new Error('Error obteniendo los datos');
                    }
                    const modelos = await response.json();
                    const modelosSelect = document.getElementById('modelos');
                    modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';
                    modelos.forEach(modelo => {
                        const option = document.createElement('option');
                        option.value = modelo.id;
                        option.text = modelo.nombre;
                        modelosSelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Error obteniendo los datos:', error);
                }
            }

        </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
    }

      
  